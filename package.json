:500;color:#0d2340}.f input,.f select,.f textarea{padding:.65rem .9rem;border:1px solid #dbeafe;border-radius:.6rem;font-size:.9rem;font-family:'DM Sans',sans-serif;background:#fff;color:#0d2340;transition:border-color .2s;outline:none;width:100%}.f input:focus,.f select:focus,.f textarea:focus{border-color:#1a5fa8}.f textarea{resize:vertical}.note{font-size:.8rem;color:#1a5fa8;background:#dbeafe;padding:.75rem 1rem;border-radius:.6rem;margin-bottom:1.25rem;line-height:1.5}.sub{width:100%;background:linear-gradient(135deg,#1a5fa8,#1D9E75);color:#fff;padding:.9rem;border-radius:.75rem;font-size:.95rem;font-weight:500;cursor:pointer;transition:opacity .2s;border:none;font-family:'DM Sans',sans-serif}.sub:hover{opacity:.9}.ok{text-align:center;padding:3rem 2rem}.ck{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#1a5fa8,#1D9E75);color:#fff;font-size:1.8rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem}.ok h3{font-family:'Fraunces',serif;font-size:1.4rem;font-weight:400;color:#0d2340;margin-bottom:.75rem}.ok p{font-size:.9rem;color:#6B7280;line-height:1.6}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         @media(max-width:900px){.i{grid-template-columns:1fr;gap:2.5rem}.s{padding:4rem 1.5rem}.row{grid-template-columns:1fr}}
