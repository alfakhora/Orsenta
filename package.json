                                                                                                   cat > src/components/Navbar.jsx << 'EOF'
                                                                                                   import{useState}from 'react'
                                                                                                   import s from './Navbar.module.css'
                                                                                                   export default function Navbar(){
                                                                                                     const[open,setOpen]=useState(false)
                                                                                                       return(
                                                                                                           <nav className={s.nav}>
                                                                                                                 <a href="#" className={s.logo}>ORSENTA<span>Your TeleDoctor</span></a>
                                                                                                                       <div className={`${s.links} ${open?s.open:''}`}>
                                                                                                                               <a href="#features" onClick={()=>setOpen(false)}>For Patients</a>
                                                                                                                                       <a href="#how" onClick={()=>setOpen(false)}>How it works</a>
                                                                                                                                               <a href="#join-doctors" onClick={()=>setOpen(false)}>For Doctors</a>
                                                                                                                                                       <a href="#specialties" onClick={()=>setOpen(false)}>Specialties</a>
                                                                                                                                                               <a href="#contact" className={s.btn} onClick={()=>setOpen(false)}>Book a visit</a>
                                                                                                                                                                     </div>
                                                                                                                                                                           <button className={s.burger} onClick={()=>setOpen(!open)}><span/><span/><span/></button>
                                                                                                                                                                               </nav>
                                                                                                                                                                                 )
                                                                                                                                                                                 }
                                                                                                                                                                                 EOF
                                                                                                                                                                                 cat > src/components/Navbar.module.css << 'EOF'
                                                                                                                                                                                 .nav{position:sticky;top:0;z-index:100;background:#fff;border-bottom:1px solid #dbeafe;padding:1rem 5%;display:flex;align-items:center;justify-content:space-between}
                                                                                                                                                                                 .logo{font-family:'Fraunces',serif;font-size:1.3rem;font-weight:700;color:#1a5fa8;letter-spacing:-.5px;line-height:1.1}
                                                                                                                                                                                 .logo span{display:block;font-size:.6rem;font-family:'DM Sans',sans-serif;color:#1D9E75;letter-spacing:2px;text-transform:uppercase}
                                                                                                                                                                                 .links{display:flex;align-items:center;gap:2rem}
                                                                                                                                                                                 .links a{color:#6B7280;font-size:.9rem;transition:color .2s}
                                                                                                                                                                                 .links a:hover{color:#1a5fa8}
                                                                                                                                                                                 .btn{background:linear-gradient(135deg,#1a5fa8,#1D9E75)!important;color:#fff!important;padding:.55rem 1.3rem;border-radius:2rem;font-weight:500!important}
                                                                                                                                                                                 .burger{display:none;flex-direction:column;gap:5px;background:none;padding:4px;border:none;cursor:pointer}
                                                                                                                                                                                 .burger span{display:block;width:22px;height:2px;background:#1a5fa8;border-radius:2px}
                                                                                                                                                                                 @media(max-width:900px){.burger{display:flex}.links{display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border-bottom:1px solid #dbeafe;padding:1.5rem 5%;flex-direction:column;align-items:flex-start;gap:1.25rem}.links.open{display:flex}}
                                                                                                                                                                                 EOF
                                                                                                                                                                                 cat > src/components/Hero.jsx << 'EOF'
                                                                                                                                                                                 import{useState}from 'react'
                                                                                                                                                                                 import s from './Hero.module.css'
                                                                                                                                                                                 const SLOTS=['9:00 AM','10:30 AM','1:00 PM','3:30 PM','5:00 PM']
                                                                                                                                                                                 export default function Hero(){
                                                                                                                                                                                   const[active,setActive]=useState(0)
                                                                                                                                                                                     return(
                                                                                                                                                                                         <section className={s.section}>
                                                                                                                                                                                               <div className={s.inner}>
                                                                                                                                                                                                       <div className={s.content}>
                                                                                                                                                                                                                 <div className={s.badge}><span className={s.dot}/>Trusted telemedicine platform</div>
                                                                                                                                                                                                                           <h1>Healthcare from the <em>comfort</em> of your home</h1>
                                                                                                                                                                                                                                     <p>Connect with certified doctors online. Get consultations, prescriptions, and follow-ups — anytime, from anywhere.</p>
                                                                                                                                                                                                                                               <div className={s.btns}>
                                                                                                                                                                                                                                                           <a href="#contact" className={s.btnP}>Book a consultation</a>
                                                                                                                                                                                                                                                                       <a href="#specialties" className={s.btnO}>Meet our doctors</a>
                                                                                                                                                                                                                                                                                 </div>
                                                                                                                                                                                                                                                                                         </div>
                                                                                                                                                                                                                                                                                                 <div className={s.card}>
                                                                                                                                                                                                                                                                                                           <div className={s.drow}>
                                                                                                                                                                                                                                                                                                                       <div className={s.avatar}>DR</div>
                                                                                                                                                                                                                                                                                                                                   <div><p className={s.dname}>Dr. Amara Osei</p><span className={s.dspec}>General Practitioner</span></div>
                                                                                                                                                                                                                                                                                                                                               <span className={s.online}>● Online</span>
                                                                                                                                                                                                                                                                                                                                                         </div>
                                                                                                                                                                                                                                                                                                                                                                   <p className={s.slbl}>Available slots — Today</p>
                                                                                                                                                                                                                                                                                                                                                                             <div className={s.slots}>{SLOTS.map((sl,i)=><button key={sl} className={`${s.slot} ${i===active?s.act:''}`} onClick={()=>setActive(i)}>{sl}</button>)}</div>
                                                                                                                                                                                                                                                                                                                                                                                       <button className={s.confirm}>Confirm appointment</button>
                                                                                                                                                                                                                                                                                                                                                                                               </div>
                                                                                                                                                                                                                                                                                                                                                                                                     </div>
                                                                                                                                                                                                                                                                                                                                                                                                         </section>
                                                                                                                                                                                                                                                                                                                                                                                                           )
                                                                                                                                                                                                                                                                                                                                                                                                           }
                                                                                                                                                                                                                                                                                                                                                                                                           EOF
                                                                                                                                                                                                                                                                                                                                                                                                           cat > src/components/Hero.module.css << 'EOF'
                                                                                                                                                                                                                                                                                                                                                                                                           .section{background:linear-gradient(160deg,#f0f7ff 0%,#e8f5e9 100%)}
                                                                                                                                                                                                                                                                                                                                                                                                           .inner{max-width:1200px;margin:0 auto;padding:6rem 5%;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
                                                                                                                                                                                                                                                                                                                                                                                                           .badge{display:inline-flex;align-items:center;gap:8px;background:rgba(26,95,168,.1);color:#1a5fa8;padding:.4rem 1rem;border-radius:2rem;font-size:.8rem;font-weight:500;margin-bottom:1.5rem}
                                                                                                                                                                                                                                                                                                                                                                                                           .dot{width:7px;height:7px;background:#1D9E75;border-radius:50%;display:inline-block;animation:pulse 2s infinite}
                                                                                                                                                                                                                                                                                                                                                                                                           @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
                                                                                                                                                                                                                                                                                                                                                                                                           .content h1{font-family:'Fraunces',serif;font-size:clamp(2.4rem,5vw,3.6rem);font-weight:300;line-height:1.15;letter-spacing:-1px;margin-bottom:1.25rem;color:#0d2340}
                                                                                                                                                                                                                                                                                                                                                                                                           .content h1 em{font-style:italic;color:#1a5fa8}
                                                                                                                                                                                                                                                                                                                                                                                                           .content p{color:#6B7280;font-size:1.05rem;line-height:1.7;margin-bottom:2.5rem;max-width:480px}
                                                                                                                                                                                                                                                                                                                                                                                                           .btns{display:flex;gap:1rem;flex-wrap:wrap}
                                                                                                                                                                                                                                                                                                                                                                                                           .btnP{background:linear-gradient(135deg,#1a5fa8,#1D9E75);color:#fff;padding:.85rem 2rem;border-radius:2rem;font-weight:500;transition:opacity .2s,transform .15s}
                                                                                                                                                                                                                                                                                                                                                                                                           .btnP:hover{opacity:.9;transform:translateY(-2px)}
                                                                                                                                                                                                                                                                                                                                                                                                           .btnO{border:1.5px solid #1a5fa8;color:#1a5fa8;padding:.85rem 2rem;border-radius:2rem;font-weight:500;transition:background .2s}
                                                                                                                                                                                                                                                                                                                                                                                                           .btnO:hover{background:rgba(26,95,168,.08)}
                                                                                                                                                                                                                                                                                                                                                                                                           .card{background:#fff;border-radius:1.5rem;border:1px solid #dbeafe;padding:2rem;box-shadow:0 8px 40px rgba(26,95,168,.12)}
                                                                                                                                                                                                                                                                                                                                                                                                           .drow{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem}
                                                                                                                                                                                                                                                                                                                                                                                                           .avatar{width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,#1a5fa8,#1D9E75);display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-weight:600;color:#fff;font-size:1rem;flex-shrink:0}
                                                                                                                                                                                                                                                                                                                                                                                                           .dname{font-weight:500;font-size:.95rem;margin-bottom:2px;color:#0d2340}
                                                                                                                                                                                                                                                                                                                                                                                                           .dspec{color:#6B7280;font-size:.8rem}
                                                                                                                                                                                                                                                                                                                                                                                                           .online{margin-left:auto;background:#e8f5e9;color:#1D9E75;padding:3px 10px;border-radius:1rem;font-size:.75rem;font-weight:500;white-space:nowrap}
                                                                                                                                                                                                                                                                                                                                                                                                           .slbl{font-size:.8rem;color:#6B7280;margin-bottom:.75rem}
                                                                                                                                                                                                                                                                                                                                                                                                           .slots{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem}
                                                                                                                                                                                                                                                                                                                                                                                                           .slot{padding:.4rem .85rem;border-radius:.5rem;border:1px solid #dbeafe;font-size:.82rem;background:#fff;color:#0d2340;transition:all .2s;cursor:pointer}
                                                                                                                                                                                                                                                                                                                                                                                                           .slot:hover,.act{background:linear-gradient(135deg,#1a5fa8,#1D9E75);color:#fff;border-color:#1a5fa8}
                                                                                                                                                                                                                                                                                                                                                                                                           .confirm{width:100%;background:linear-gradient(135deg,#1a5fa8,#1D9E75);color:#fff;padding:.85rem;border-radius:.75rem;font-size:.9rem;font-weight:500;transition:opacity .2s;cursor:pointer;border:none}
                                                                                                                                                                                                                                                                                                                                                                                                           .confirm:hover{opacity:.9}
                                                                                                                                                                                                                                                                                                                                                                                                           @media(max-width:768px){.inner{grid-template-columns:1fr;gap:2rem;padding:3rem 1.5rem}.card{display:none}}
                                                                                                                                                                                                                                                                                                                                                                                                           EOF
